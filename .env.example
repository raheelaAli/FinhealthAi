# ─────────────────────────────────────────────────────────────
# FinHealth AI — Environment Variables
# Copy this file to .env.local and fill in YOUR values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────────

# ── Node.js version requirement ───────────────────────────────
# Next.js 16 requires Node.js >= 20.9.0
# Check yours: node --version
# Download LTS: https://nodejs.org

# ── Database (Neon PostgreSQL — free tier) ────────────────────
# 1. Go to https://neon.tech → Sign up free (no credit card)
# 2. Create a project → Copy the connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────
# Generate NEXTAUTH_SECRET by running in your terminal:
#   openssl rand -base64 32
NEXTAUTH_SECRET="paste-your-generated-secret-here"

# Your app URL (change to your Vercel URL when deploying)
NEXTAUTH_URL="http://localhost:3000"

# ── Google Gemini API (free — 1500 req/day, no credit card) ──
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Sign in with Google → "Create API key" → Copy it here
GEMINI_API_KEY="paste-your-gemini-api-key-here"
